# App
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/agentic_author

# OpenRouter (for Grok model - https://openrouter.ai)
# Get your API key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
# Note: Web search uses DuckDuckGo (no API key required)

# Gmail SMTP
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your-secret-key-here
PAYSTACK_PUBLIC_KEY=pk_live_your-public-key-here
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your-public-key-here

 # For Tracing and Debugging
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
